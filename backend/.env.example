# ==============================
# Environment Configuration
# Copy this file to .env and fill in values
# ==============================

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# File Storage
UPLOAD_DIR=./uploads
RESULTS_DIR=./results

# Detection Model
# Options: "florence2", "grounding_dino"
DETECTION_MODEL=grounding_dino

# GPU Device (e.g. "cuda:0", "cuda:1", "cpu")
DEVICE=cuda:0

# Florence-2 model variant (if using Florence-2)
FLORENCE2_MODEL_ID=microsoft/Florence-2-large

# Grounding DINO config and checkpoint (if using Grounding DINO)
GDINO_CONFIG_PATH=./models/groundingdino/config/GroundingDINO_SwinT_OGC.py
GDINO_CHECKPOINT_PATH=./models/groundingdino/weights/groundingdino_swint_ogc.pth

# Detection thresholds
BOX_THRESHOLD=0.35
TEXT_THRESHOLD=0.25

# ByteTrack parameters
TRACK_THRESH=0.5
TRACK_BUFFER=30
MATCH_THRESH=0.8

# Frame sampling: run detection every N frames, track in between
DETECTION_INTERVAL=5

# Max concurrent tasks (GPU memory constraint)
MAX_CONCURRENT_TASKS=2

# Optional: Redis URL for Celery task queue
# REDIS_URL=redis://localhost:6379/0
