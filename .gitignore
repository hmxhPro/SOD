# ───────────────────────────────────────────────────────────────
# Large data directories (videos, model weights, results, caches)
# ───────────────────────────────────────────────────────────────
backend/uploads/
backend/results/
backend/models/
backend/logs/

# ───────────────────────────────────────────────────────────────
# Python
# ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
*.whl

# Virtual environments
venv/
env/
.venv/
.env.*
!.env.example

# Testing / coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/

# Jupyter
.ipynb_checkpoints/

# ───────────────────────────────────────────────────────────────
# Node / frontend
# ───────────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp
.pnp.js

# ───────────────────────────────────────────────────────────────
# Model weights / checkpoints / datasets (any location)
# ───────────────────────────────────────────────────────────────
*.pth
*.pt
*.bin
*.safetensors
*.onnx
*.ckpt
*.h5
*.tflite
*.engine
*.trt

# ───────────────────────────────────────────────────────────────
# Media / result artifacts (any location)
# ───────────────────────────────────────────────────────────────
*.mp4
*.avi
*.mov
*.mkv
*.webm
*.flv
*.wmv
*.m4v

# keep the reference image tracked — ignore bulk images elsewhere if needed
# (screenshots, generated frames)
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# ───────────────────────────────────────────────────────────────
# Logs
# ───────────────────────────────────────────────────────────────
*.log
logs/

# ───────────────────────────────────────────────────────────────
# OS / editor / IDE
# ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
!.vscode/settings.json.example

# ───────────────────────────────────────────────────────────────
# Secrets / local config
# ───────────────────────────────────────────────────────────────
.env
*.pem
*.key
